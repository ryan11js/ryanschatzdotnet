# Dependencies
node_modules/

# Environment and local secrets
.env
.env.*
!.env.example

# Local editor state
.vscode/
.idea/

# OS metadata
.DS_Store
Thumbs.db
Desktop.ini

# Logs and local preview artifacts
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
server.*.log
preview-*.png

# Runtime caches generated by the PHP/Node APIs
cache/*.json
!cache/.gitkeep
.cache/

# Beat audio stays out of Git; upload/sync to cPanel public_html/media/beats.
media/beats/**
!media/beats/
!media/beats/.gitkeep
*.mp3
*.m4a
*.wav
*.aif
*.aiff
*.flac
*.ogg
*.webm

# Temporary files
tmp/
temp/
*.tmp
local-beats/
drive-export/

# cPanel or FTP credentials/backups that should stay local
.ftpconfig
.vscode/sftp.json
*.sql
*.zip
*.tar
*.tar.gz
